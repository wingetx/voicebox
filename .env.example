# ─── Relay ───────────────────────────────────────────────────────────
# WebSocket port the relay listens on
PORT=4869

# Path to the SQLite database file (absolute or relative to relay working dir)
DB_PATH=voicebox-relay.db

# ─── UI (Next.js) ────────────────────────────────────────────────────
# Public WebSocket URL for the relay. Browser clients connect to this.
# In development: ws://localhost:4869
# In production: wss://relay.voiceboxai.app  (or wss://your-domain.com/relay)
NEXT_PUBLIC_RELAY_URL=ws://localhost:4869

# ─── Docker Compose ──────────────────────────────────────────────────
# Passed as a build arg to the UI image so the browser knows where the relay is.
# For a VPS with a public IP and no domain yet:
#   RELAY_URL=ws://YOUR_SERVER_IP:4869
# For a domain with TLS (nginx in front):
#   RELAY_URL=wss://relay.yourdomain.com
RELAY_URL=ws://localhost:4869
